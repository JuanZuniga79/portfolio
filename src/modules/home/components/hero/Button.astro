---
interface Props{
  label: string,
  href: string,
  special?: boolean,
}
const {label, href, special} = Astro.props;
---
<button class={`outline-none ring-0 px-4 py-2 border-4 border-white hover:bg-blue-500 
            ${special && 'bg-blue-500 text-white'}
            hover:text-white transition-all duration-300 ease-linear hover:scale-110`}>
    <a href={href} class="w-full h-full">{label}</a>
</button>
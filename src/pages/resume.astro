---
import RootLayout from "@/core/layouts/RootLayout.astro"
import ResumeLayout from "../modules/resume/layout/ResumeLayout.astro";
import Profile from "../modules/resume/components/Profile.astro";
import About from "../modules/resume/components/About.astro";
import Experience from "../modules/resume/components/Experience.astro";
import Skills from "../modules/resume/components/Skills.astro";
import Education from "../modules/resume/components/Education.astro";
import Projects from "../modules/resume/components/Projects.astro";
const lang = Astro.currentLocale!;
const title = lang === "en" ? "Resume" : "Resumen";
---
<RootLayout title={title}>
    <ResumeLayout>
        <Profile/>
        <About/>
        <Education/>
        <Experience/>
        <Projects/>
        <Skills/>
    </ResumeLayout>
</RootLayout>
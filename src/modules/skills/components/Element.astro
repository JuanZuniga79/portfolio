---
import type ISoftSkill from "../data/types/ISoftSkill"
interface Props{
    item: ISoftSkill
}
const {item} = Astro.props
---
<li
    class="border-2 flex flex-col h-full gap-y-2 rounded-xl list-none p-4 bg-gray-100 bg-opacity-50 backdrop-blur-md
                    dark:bg-slate-800 dark:border-slate-600 dark:bg-opacity-60"
>
    <h3 class="capitalize text-lg italic font-semibold">{item.name}</h3>
    <p class="text-sm">
        {item.description}
    </p>
</li>

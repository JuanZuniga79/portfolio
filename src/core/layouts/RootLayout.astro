---
import {ClientRouter} from "astro:transitions"
import "@core/styles/css/global.css"
import Header from "@core/components/sections/Header.astro";
import Footer from "@core/components/sections/Footer.astro";
interface Props{
    title: string,
}
const {title} = Astro.props;
const lang = Astro.currentLocale;
if(!lang) return;
---
<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Bellota:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&display=swap"
              rel="stylesheet">
        <meta name="generator" content={Astro.generator} />
        <ClientRouter/>
        <title>{title}</title>
    </head>
    <body class="bg-gray-100 overflow-x-hidden">
        <Header/>
        <main class="w-dvw h-fit flex flex-col scroll-smooth">
            <slot />
        </main>
        <Footer/>
    </body>
</html>
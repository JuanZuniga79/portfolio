---
import Section from "@core/layouts/Section.astro";
import hobbies from "@about/data/hobbies";
import Card from "@core/components/cards/Card.astro";
const lang = Astro.currentLocale!;
const title = lang === "en" ? "Hobbies" : "Pasatiempos";
const bar = lang === "en" ? "Frecuency" : "Frecuencia";
---

<Section title={title} id="hobbies">
  <ul class="w-full grid grid-cols-3 gap-5 items-stretch">
    {hobbies(lang).map((hobbie) => <Card data={hobbie} bar={bar} />)}
  </ul>
</Section>

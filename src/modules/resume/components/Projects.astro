---
import ResumeSection from "../layout/ResumeSection.astro"
import {Image} from "astro:assets"
import {projects} from "../data/projects";
const lang = Astro.currentLocale!;
const title = lang === 'en' ? "Projects" : "Proyectos";
const done = lang === 'en' ? "Done!" : "Terminado!";
const unfinished = lang === 'en' ? "Unfinished!" : "En curso";
---
<ResumeSection title={title}>
    <ul class="grid grid-cols-3 gap-5 items-stretch">
        {projects(lang).map(project => (
            <li class="w-full h-fit bg-white rounded-2xl px-4 py-2 relative">
                <figure class={`absolute -top-4 -right-4 px-2 py-1.5 rounded-2xl
                    ${project.status ? 'bg-green-600 text-green-100' : 'bg-amber-600 text-amber-100'}
                `}>
                    {project.status ? done : unfinished}
                </figure>
                <Image src={project.image} alt="project" width={200} height={200}
                       class="w-full h-1/2 object-center" />
                <h4 class="text-xl font-bold">{project.title}</h4>
                <span class="text-sm whitespace-pre-line">{project.description}</span>
            </li>
        ))}
    </ul>
</ResumeSection>
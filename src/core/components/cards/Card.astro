---
import type { ICard } from "@core/types/ICards";

interface Props {
  data: ICard;
  bar?: string;
}
const { data, bar } = Astro.props;
const lang = Astro.currentLocale!;
---

<li class="w-full h-full rounded-2xl overflow-hidden">
  <div
    class={`w-full h-fit px-8 pt-8 pb-2 text-white bg-gradient-to-r ${data.class[0]} ${data.class[1]} flex flex-col gap-y-5`}
  >
    <figure
      class="w-12 h-12 p-2 bg-white/50 rounded-full place-self-end flex items-center justify-center"
    >
      <data.icon />
    </figure>
    <div>
      <h3 class="text-3xl">{data.title}</h3>
      <h4>{data.subtitle}</h4>
    </div>
  </div>
  <div class="w-full h-full p-5 flex flex-col gap-y-4 bg-white text-black">
    {
      data.level && bar && (
        <div class="w-full">
          <p class="font-semibold">{bar}</p>
          <figure class="w-full rounded-2xl bg-gray-100 overflow-hidden">
            <ul
              class={`bg-gradient-to-r ${data.class[0]} ${data.class[1]} flex items-center rounded-2xl`}
              style={{ width: `${data.level * 10}%` }}
            >
              {"\u200B"}
            </ul>
          </figure>
        </div>
      )
    }
    <p class="whitespace-pre-line w-full">{data.description}</p>
  </div>
</li>

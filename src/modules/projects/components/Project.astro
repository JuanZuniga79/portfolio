--- import type IProject from "../data/types/IProject"; interface Props {
    lang: string
    project: IProject;
}
const { project, lang } = Astro.props;
---

<li
    class="text-sm w-full h-full rounded-2xl flex flex-col gap-y-1 overflow-hidden bg-slate-200 dark:bg-slate-800 border-2 border-slate-100 dark:border-slate-700 bg-opacity-30 backdrop-blur-sm"
>
    <img src={project.cover} alt={project.name} class="w-full h-full" />
    <div class="flex flex-col w-full h-full px-2 py-4">
        <h4 class="text-xl italic">{project.name}</h4>
        <p>Priority: {project.priority}/10</p>
        <span
            class={`${project.status ? "text-green-500" : "text-amber-400"} italic`}
            >{project.status ? "Done" : "In Progress"}</span
        >
        <p>
            Project Size: <span class="capitalize font-medium"
                >{project.size}</span
            >
        </p>
        <p class={`${project.public ? "text-green-500" : "text-red-500"}`}>
            {project.public ? "Public" : "Private"} Repository
        </p>
        <a href={`${lang === "en" ? "":"es" }/projects/${project.id}`} class="underline underline-offset-1 capitalize">See more details</a>
        <div class="flex gap-x-4 items-center justify-center mt-2">
            {project.technologies.map((item)=>(
                <figure class="w-8 h-8">
                    <item.icon/>
                </figure>
            ))}
        </div>
        {project.public && (
            <div class="w-full flex items-center justify-center mt-5">
                <button class="outline-none">
                    <a 
                        href={project.repository} 
                        target="_blank" 
                        class="w-56 h-8 rounded-full flex items-center justify-center bg-indigo-300 hover:bg-indigo-400 dark:bg-indigo-600 dark:hover:bg-indigo-500 dark:text-white"> Repository
                    </a>
                </button>
            </div>
        )}
    </div>
</li>
